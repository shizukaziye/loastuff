{
  "name": "astrogem-calculator",
  "version": "0.1.0",
  "description": "Lost Ark astrogem-cutting calculator: a dependency-free verified model core (JS + Python mirror) with an app shell for a Pipeline (batch EV) and Advisor (live per-turn) UI.",
  "private": true,
  "scripts": {
    "verify": "node verify.js",
    "verify-dp": "node tools/verify-dp.js",
    "verify-dp-selfcheck": "node tools/verify-dp.js --selfcheck",
    "genrefs": "node tools/gen-refs.js",
    "eval-ocr": "node tools/eval-ocr.js",
    "lint-labels": "node tools/lint-labels.js",
    "eval-gate": "node tools/lint-labels.js && node tools/eval-ocr.js --engines=structural --gate=structural:0.95,0.95",
    "serve": "npx http-server -p 8080 -c-1 ."
  },
  "license": "MIT",
  "devDependencies": {
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0"
  }
}
